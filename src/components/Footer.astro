---
import type { Lang } from '../utils/i18n';
import { t, getLocalizedUrl } from '../utils/i18n';
import { getAllCategories } from '../utils/news';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const categories = getAllCategories();
const categoryBasePath = lang === 'tr' ? '/kategori' : '/en/category';
---

<footer class="bg-navy-950 text-slate-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Hakkımızda -->
      <div>
        <h3 class="font-heading font-bold text-white text-lg mb-4">{t('site.name', lang)}</h3>
        <p class="text-sm text-slate-400 leading-relaxed font-body">
          {t('footer.about', lang)}
        </p>
      </div>

      <!-- Hızlı Linkler -->
      <div>
        <h3 class="font-heading font-bold text-white text-lg mb-4">{t('footer.quickLinks', lang)}</h3>
        <ul class="space-y-2">
          <li>
            <a href={getLocalizedUrl('/', lang)} class="text-sm text-slate-400 hover:text-cyan-400 transition-colors font-body">
              {t('nav.home', lang)}
            </a>
          </li>
          {categories.map((cat) => (
            <li>
              <a
                href={`${categoryBasePath}/${cat.slug}/`}
                class="text-sm text-slate-400 hover:text-cyan-400 transition-colors font-body"
              >
                {cat.label[lang]}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- İletişim -->
      <div>
        <h3 class="font-heading font-bold text-white text-lg mb-4">{t('footer.contact', lang)}</h3>
        <ul class="space-y-2">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-cyan-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            <span class="text-sm text-slate-400 font-body">{t('footer.email', lang)}</span>
          </li>
        </ul>
        <!-- Sosyal medya -->
        <div class="flex gap-4 mt-4">
          <a href="#" class="text-slate-400 hover:text-cyan-400 transition-colors" aria-label="Twitter">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" /></svg>
          </a>
          <a href="#" class="text-slate-400 hover:text-cyan-400 transition-colors" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" /></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-slate-700 mt-8 pt-8 text-center">
      <p class="text-sm text-slate-500 font-body">{t('footer.copyright', lang)}</p>
    </div>
  </div>
</footer>
