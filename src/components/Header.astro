---
import type { Lang } from '../utils/i18n';
import { t, getLocalizedUrl } from '../utils/i18n';
import { getAllCategories } from '../utils/news';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const categories = getAllCategories();
const categoryBasePath = lang === 'tr' ? '/kategori' : '/en/category';
---

<header class="bg-navy-950 text-white sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={getLocalizedUrl('/', lang)} class="font-heading font-bold text-xl text-white hover:text-cyan-400 transition-colors">
        {t('site.name', lang)}
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-6" aria-label={lang === 'tr' ? 'Ana navigasyon' : 'Main navigation'}>
        <a href={getLocalizedUrl('/', lang)} class="text-slate-200 hover:text-cyan-400 transition-colors font-body text-sm font-medium">
          {t('nav.home', lang)}
        </a>

        <!-- Kategoriler dropdown (CSS-only) -->
        <details class="relative group">
          <summary class="text-slate-200 hover:text-cyan-400 transition-colors font-body text-sm font-medium cursor-pointer list-none flex items-center gap-1">
            {t('nav.categories', lang)}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="absolute top-full left-0 mt-2 w-48 bg-white rounded-lg shadow-lg py-2 z-50">
            {categories.map((cat) => (
              <a
                href={`${categoryBasePath}/${cat.slug}/`}
                class="block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 hover:text-cyan-500 transition-colors"
              >
                {cat.label[lang]}
              </a>
            ))}
          </div>
        </details>
      </nav>

      <div class="hidden md:flex items-center">
        <!-- Dil değiştirici -->
        <a
          href={t('lang.switchUrl', lang)}
          class="text-sm text-slate-300 hover:text-cyan-400 transition-colors border border-slate-600 rounded px-3 py-1"
        >
          {t('lang.switch', lang)}
        </a>
      </div>

      <!-- Mobil menü (CSS-only) -->
      <details class="md:hidden">
        <summary class="text-white cursor-pointer list-none p-2" aria-label={lang === 'tr' ? 'Menüyü aç' : 'Open menu'}>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
        </summary>
        <div class="absolute top-16 left-0 right-0 bg-navy-950 border-t border-slate-700 px-4 py-4 z-50">
          <nav class="flex flex-col gap-3" aria-label={lang === 'tr' ? 'Mobil navigasyon' : 'Mobile navigation'}>
            <a href={getLocalizedUrl('/', lang)} class="text-slate-200 hover:text-cyan-400 py-2 font-body">
              {t('nav.home', lang)}
            </a>
            {categories.map((cat) => (
              <a
                href={`${categoryBasePath}/${cat.slug}/`}
                class="text-slate-300 hover:text-cyan-400 py-2 font-body text-sm pl-4"
              >
                {cat.label[lang]}
              </a>
            ))}
            <a
              href={t('lang.switchUrl', lang)}
              class="text-cyan-400 hover:text-cyan-300 py-2 font-body text-sm border-t border-slate-700 mt-2 pt-4"
            >
              {t('lang.switch', lang)}
            </a>
          </nav>
        </div>
      </details>
    </div>
  </div>
</header>
