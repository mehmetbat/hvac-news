---
import type { Lang } from '../utils/i18n';
import { t } from '../utils/i18n';

interface BreadcrumbItem {
  label: string;
  url: string;
}

interface Props {
  items: BreadcrumbItem[];
  lang: Lang;
}

const { items, lang } = Astro.props;
const homeUrl = lang === 'tr' ? '/' : '/en/';
---

<nav aria-label={lang === 'tr' ? 'Sayfa izi' : 'Breadcrumb'} class="mb-6">
  <ol class="flex flex-wrap items-center gap-1 text-sm text-slate-500 font-body">
    <li>
      <a href={homeUrl} class="hover:text-cyan-500 transition-colors">
        {t('breadcrumb.home', lang)}
      </a>
    </li>
    {items.map((item, index) => (
      <li class="flex items-center gap-1">
        <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        {index === items.length - 1 ? (
          <span class="text-slate-900 font-medium">{item.label}</span>
        ) : (
          <a href={item.url} class="hover:text-cyan-500 transition-colors">{item.label}</a>
        )}
      </li>
    ))}
  </ol>
</nav>
